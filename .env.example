VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe — frontend only (publishable key and price ID are safe to expose)
# Never put STRIPE_SECRET_KEY or STRIPE_WEBHOOK_SECRET here — those belong in Supabase Edge Function secrets
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_ID=price_...

# EmailJS — feedback form (beta validation)
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
