{
  "permissions": {
    "allow": [
      "Bash(Get-ChildItem *)",
      "Bash(New-Item -ItemType File -Path \"C:\\\\Users\\\\nikec\\\\Desktop\\\\jd-skill-parser\\\\tests\\\\unit\\\\registry.test.js\" -Force)",
      "Bash(Out-Null)",
      "Bash(node --input-type=module)",
      "Bash(Select-Object FullName)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(dir C:\\\\Users\\\\nikec\\\\Desktop\\\\nat20-core\\\\offline_tests\\\\resume-samples *)",
      "Bash(npm run *)",
      "Bash(curl -s http://localhost:5999)",
      "Bash(npx playwright *)",
      "PowerShell(*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/session-start.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/block-dangerous.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/auto-test.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/auto-update-plan.ps1"
          }
        ]
      }
    ]
  }
}